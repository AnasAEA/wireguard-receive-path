// GRO simplifié pour la diapo 8 — vertical, gros texte
digraph GROSLIDE {
  rankdir=TB; fontname="Helvetica"; nodesep=0.4; ranksep=0.5; bgcolor="transparent";
  node [fontname="Helvetica", fontsize=16, style="rounded,filled", fillcolor=white];
  edge [fontname="Helvetica", fontsize=13, penwidth=1.6];

  IN  [label="4 paquets du MÊME flux  (paquet 1 · 2 · 3 · 4)", fillcolor="#dbeafe"];
  GRO [label="on les AGRAFE au lieu de monter tout de suite\n= napi_gro_receive   (receive.c:411)", shape=hexagon, fillcolor="#dcfce7"];
  BIG [label="UN seul gros colis  (1+2+3+4)", fillcolor="#bbf7d0"];
  UP  [label="napi_complete_done → gro_flush_normal :\nUNE seule traversée de pile au lieu de 4\n(le « péage » par paquet est payé 1 fois)", fillcolor="#dcfce7"];
  FRONTS [label="2 fronts chez WireGuard :\n#1 externe chiffré (carte) — CONDITIONNEL\n#2 interne déchiffré (wg0) — EXPLICITE", shape=note, fillcolor="#fef9c3"];

  IN -> GRO -> BIG -> UP;
  UP -> FRONTS [style=invis];
}
