// Simplified pipeline for slide ("we assemble") — snake layout: the flow turns
// DOWN into the red napi_schedule box to emphasise the break point.
digraph PIPE {
  rankdir=TB; fontname="Helvetica"; nodesep=0.5; ranksep=0.8; bgcolor="transparent";
  node [fontname="Helvetica", fontsize=15, style="rounded,filled", shape=box];
  edge [fontname="Helvetica", fontsize=12, penwidth=1.8];

  A1 [label="(1)  NIC: driver's NAPI\n+ GRO #1 (conditional)\nudp_offload.c:800", fillcolor="#dbeafe"];
  A2 [label="(2)  WireGuard receives →\ntwo-phase enqueue:\n- ORDERED queue (per peer)\n- queue_work_on(cpu)\nqueueing.h:152", fillcolor="#dbeafe"];
  B1 [label="(3)  per-CPU WORKQUEUE\ndecrypts IN PARALLEL\n→ finishes OUT OF ORDER\nreceive.c:493", fillcolor="#fee2e2"];
  B2 [label="(4)  napi_schedule\nUNCONDITIONAL\nqueueing.h:196", fillcolor="#fecaca", color="#b91c1c", penwidth=3];
  C1 [label="(5)  WireGuard's NAPI:\nwg_packet_rx_poll\nstops at first UNCRYPTED\n→ EMPTY polls\nreceive.c:451", fillcolor="#dcfce7"];
  C2 [label="(6)  GRO #2 → application\nreceive.c:411", fillcolor="#dcfce7"];

  // Row 1, left to right
  { rank=same; A1 -> A2 -> B1; }
  // Row 2, laid right to left (dir=back keeps the arrows pointing with the flow)
  { rank=same; C2 -> C1 [dir=back]; C1 -> B2 [dir=back]; }

  // The break: a bold red arrow turns DOWN from the workqueue into napi_schedule
  B1 -> B2 [color="#b91c1c", penwidth=3.2, label="  every packet,\n  out of order"];
}
